<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mini Message Board</title>
</head>
<body>
    <h1> Yeah it works bruh </h1>
    <p>Messages: <strong><%= messages.length %></strong></p>
    <ul>
       <% messages.forEach((msg) => { %> 
        <li>
            #<%= msg.id %> —
            <%= msg.user %> :
            <%= msg.text %>
            <a href="/messages/<%= msg.id %>">Open</a>
        </li>
       <% }); %>
    </ul>
    <a href="/new/"> Add a message </a>
</body>
</html>